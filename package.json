{
  "name": "qr-reader",
  "version": "1.0.0",
  "description": "画像を右クリックしてQRコードを読み取り、別タブで開く",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "npm run generate-icons && wxt build",
    "zip": "npm run generate-icons && wxt zip",
    "typecheck": "wxt prepare && tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "generate-icons": "node scripts/generate-icons.mjs",
    "postinstall": "wxt prepare"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "ISC",
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wxt": "^0.20.26"
  },
  "dependencies": {
    "jsqr": "^1.4.0"
  }
}
